{
  "name": "agent-rbac",
  "version": "0.1.0",
  "description": "Role-based access control and memory isolation framework for multi-user AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/openclaw-plugin.js"
    ]
  },
  "bin": {
    "agent-rbac": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "import": "./dist/cli.js"
    },
    "./adapters/openclaw": {
      "types": "./dist/adapters/openclaw.d.ts",
      "import": "./dist/adapters/openclaw.js"
    },
    "./adapters/claude-code": {
      "types": "./dist/adapters/claude-code.d.ts",
      "import": "./dist/adapters/claude-code.js"
    },
    "./adapters/codex": {
      "types": "./dist/adapters/codex.d.ts",
      "import": "./dist/adapters/codex.js"
    },
    "./openclaw-plugin": {
      "import": "./dist/openclaw-plugin.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "docs",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "picomatch": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/picomatch": "^3.0.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
